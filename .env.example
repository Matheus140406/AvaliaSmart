# ============================================================
# AvaliaSmart — variáveis de ambiente
# Copie para .env e preencha. Nenhuma delas tem default seguro.
# ============================================================

# --- Banco (Supabase PostgreSQL ou qualquer Postgres) ---
# Supabase: abre o projeto > botão "Connect" (topo do dashboard) > aba ORMs > Prisma
# — ele já te dá as duas strings formatadas certas.
#
# DATABASE_URL = pooler de TRANSAÇÃO (porta 6543, ?pgbouncer=true) — usada
# pelo app em runtime (muitas conexões curtas, ideal pra serverless).
DATABASE_URL="postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
#
# DIRECT_URL = conexão DIRETA (porta 5432, sem pooler) — usada só pelo
# `prisma migrate`. Migrations precisam de advisory locks que o pooler em
# modo transação não suporta.
DIRECT_URL="postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"
#
# Em [YOUR-PASSWORD]: se sua senha tiver caracteres especiais (#, @, /, etc.),
# faz URL-encode deles (# vira %23) ou troca a senha por uma só com letras e
# números — evita erro de parsing bem chato de debugar.

# --- Auth.js (NextAuth v5) ---
# Gere com: npx auth secret   (ou: openssl rand -base64 32)
AUTH_SECRET=""

# Google OAuth (console.cloud.google.com > Credentials > OAuth 2.0 Client)
# Redirect URI: https://SEU-DOMINIO/api/auth/callback/google
# (e http://localhost:3000/api/auth/callback/google em dev)
# Login por e-mail/senha funciona sem estes dois — só o botão Google exige.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- IA (OCR, resumo de desempenho, sugestão de observação, chat, gerador de
# prova, plano de aula, correção de redação — via Vercel AI SDK, 3 providers
# com circuit breaker, ver services/ai/ai.service.ts + client.ts) ---
#
# Ordem de tentativa: Gemini -> OpenAI -> Anthropic. Cada um só entra na
# jogada se o(s) anterior(es) falharem por cota/crédito (circuit breaker de
# 60s por provider); qualquer um pode ficar sem key definida (vira "pulo
# silencioso", não erro) — só não deixe os 3 vazios.

# aistudio.google.com > Get API key. Tier gratuito com RPM baixo (5 req/min
# no modelo Flash) — é por isso que tem fallback pros outros dois.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-flash-latest"

# platform.openai.com > API keys.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# console.anthropic.com > API Keys
ANTHROPIC_API_KEY=""
# claude-haiku-4-5 (padrão, custo baixo/volume alto) ou claude-sonnet-5 (mais qualidade, custo maior).
# Trocar aqui não exige redeploy de código.
ANTHROPIC_MODEL="claude-haiku-4-5"

# --- Pagamentos ---
# Escolha UM gateway preenchendo suas variáveis — Mercado Pago tem
# prioridade se ambos estiverem configurados (ver checkout/route.ts).
# Sem nenhum dos dois, o checkout roda em "modo dev" (aplica o plano
# direto, só fora de produção).

# Mercado Pago: painel > Suas integrações > sua aplicação > Credenciais.
# Use as de TESTE (TEST-...) primeiro; troque pra produção (APP_USR-...)
# só depois de validar o fluxo inteiro no sandbox.
MERCADOPAGO_ACCESS_TOKEN=""

# Gerado ao configurar o webhook em Suas integrações > Webhooks (valida o
# header x-signature — ver o comentário em lib/billing/mercadopago.ts).
# OBRIGATÓRIO em produção — sem isso o webhook recusa todo evento de
# propósito (ver checagem em api/billing/webhook/mercadopago/route.ts).
MERCADOPAGO_WEBHOOK_SECRET=""

# Public Key (painel > Credenciais, ao lado do Access Token).
# NÃO USADA pelo código atual — nosso fluxo é redirect pro checkout
# hospedado do Mercado Pago (/preapproval + init_point), que não precisa
# dela. Essa chave só passa a importar se um dia vocês migrarem pro
# Checkout Bricks/Payment Brick (formulário de cartão embutido nas SUAS
# páginas, tokenizado no browser) — nesse caso ela entraria no client-side
# SDK do MP. Deixada aqui documentada, não conectada a nada por enquanto.
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=""

# Asaas: painel > Integrações > Chaves de API.
# Sandbox ($aact_hmlg_...) ou produção ($aact_prod_...) — o app deduz o
# ambiente pelo prefixo da chave.
ASAAS_API_KEY=""
# Token que VOCÊ define ao cadastrar o webhook no Asaas, apontando para:
#   https://SEU-DOMINIO/api/billing/webhook
# Eventos necessários: PAYMENT_CONFIRMED, PAYMENT_RECEIVED, PAYMENT_OVERDUE.
ASAAS_WEBHOOK_TOKEN=""

# --- E-mail transacional (Resend) ---
# resend.com > API Keys. Sem isso, e-mails só ficam logados no console
# (não bloqueia nada — pagamento continua sendo confirmado normalmente).
RESEND_API_KEY=""
EMAIL_FROM="AvaliaSmart <notificacoes@seudominio.com>"

# --- Cron (aviso de assinatura vencendo) ---
# Qualquer string aleatória forte — a Vercel usa pra autenticar as chamadas
# de cron automaticamente (Bearer no header Authorization). Gere com:
# openssl rand -hex 32
CRON_SECRET=""

# --- Financeiro (visão cross-tenant Adimplente/Inadimplente em /financeiro) ---
# E-mails (separados por vírgula) autorizados a ver /financeiro e
# /api/platform/billing — status de TODOS os workspaces, não é role de
# tenant. Sem isso configurado, ninguém acessa (default seguro).
PLATFORM_ADMIN_EMAILS=""

# --- Facebook OAuth ---
# developers.facebook.com > seu app > Configurações Básicas.
# Redirect URI: https://SEU-DOMINIO/api/auth/callback/facebook
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
